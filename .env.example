# Nicholas Game - 生產環境變數範本
# 複製此檔案為 .env 並填入實際值
# 警告：.env 檔案包含機密，請勿提交到版本控制

# ===== 必填：網域設定 =====
# 您的網域名稱（不含 https://）
DOMAIN=your-domain.com

# ===== 必填：資料庫憑證 =====
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me-strong-password

# MongoDB 連線字串（自動由上面設定組合，如需自訂可覆寫）
MONGODB_URI=mongodb://admin:change-me-strong-password@mongodb:27017/nicholas-game?authSource=admin

# ===== 必填：Redis 密碼 =====
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379

# ===== 必填：應用程式機密 =====
# JWT 簽章金鑰（建議使用 openssl rand -base64 64 生成，至少 64 字元）
# 生成方式：openssl rand -base64 64
JWT_SECRET=change-me-replace-with-64-char-secret-use-openssl-rand-base64-64

# ===== 選填：錯誤追蹤 =====
# Sentry DSN（可從 https://sentry.io 取得）
SENTRY_DSN=

# ===== 選填：允許的跨域來源 =====
# 以逗號分隔，生產環境建議指定
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ===== Docker Image 設定 =====
# GitHub 倉庫（格式：owner/repo，小寫）
GITHUB_REPOSITORY=cancleeric/gress-herbalism
# 映像標籤（由 CI/CD 自動填入，本地測試可使用 latest）
IMAGE_TAG=latest

# ===== Let's Encrypt 設定 =====
# 申請 SSL 憑證的電子郵件
CERTBOT_EMAIL=your-email@example.com

# ===== 伺服器設定（供 GitHub Actions 部署使用）=====
# SERVER_HOST=your-server-ip-or-hostname
# SERVER_USER=deploy
# 請將 SSH 私鑰新增到 GitHub Secrets（SSH_PRIVATE_KEY）
