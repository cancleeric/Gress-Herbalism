{
  "name": "herbalism-backend",
  "version": "1.0.0",
  "description": "本草 Herbalism - 後端服務（可選）",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "coverageDirectory": "<rootDir>/backend/coverage",
    "rootDir": "..",
    "roots": [
      "<rootDir>/backend",
      "<rootDir>/shared"
    ],
    "collectCoverageFrom": [
      "<rootDir>/backend/**/*.js",
      "<rootDir>/shared/**/*.js",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/__tests__/**",
      "!**/tests/**"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/frontend/"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/frontend/",
      "<rootDir>/shared/constants.test.js"
    ]
  },
  "keywords": [
    "game",
    "table-game",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.91.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}