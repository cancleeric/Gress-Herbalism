{
  "name": "herbalism-frontend",
  "version": "1.0.0",
  "description": "本草 Herbalism - 前端應用",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:performance": "node --expose-gc node_modules/.bin/react-scripts test --testPathPattern=performance --testPathIgnorePatterns=/helpers/ --verbose --no-cache",
    "eject": "react-scripts eject",
    "cypress:open": "cypress open --config-file ../cypress.config.js",
    "cypress:run": "cypress run --config-file ../cypress.config.js",
    "cypress:run:mobile": "cypress run --config-file ../cypress.config.js --spec '../tests/e2e/mobile/**/*.spec.js'",
    "e2e": "start-server-and-test start http://localhost:3000 cypress:run",
    "e2e:open": "start-server-and-test start http://localhost:3000 cypress:open"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "firebase": "^12.8.0",
    "framer-motion": "^12.29.2",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.2",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.20.0",
    "redux": "^4.2.1",
    "redux-persist": "^6.0.0",
    "reselect": "^5.1.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.3.1",
    "cypress": "^13.6.0",
    "react-scripts": "5.0.1",
    "start-server-and-test": "^2.0.3"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "jest": {
    "testMatch": [
      "<rootDir>/src/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/*.spec.{js,jsx,ts,tsx}"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
